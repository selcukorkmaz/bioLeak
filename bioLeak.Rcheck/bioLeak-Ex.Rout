+   )
+   fit <- fit_resample(df, outcome = "outcome", splits = splits,
+                       learner = "glm", custom_learners = custom,
+                       metrics = "auc", refit = FALSE, seed = 1)
+   audit <- audit_leakage(fit, metric = "auc", B = 20)
+   plot_perm_distribution(audit)
+ }
