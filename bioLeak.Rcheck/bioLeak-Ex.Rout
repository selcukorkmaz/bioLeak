> ### Name: .guard_fit
> ### Title: Fit leakage-safe preprocessing pipeline
> ### Aliases: .guard_fit
> 
> ### ** Examples
> 
> x <- data.frame(a = c(1, 2, NA), b = c(3, 4, 5))
> fit <- .guard_fit(x, y = c(1, 2, 3),
+                   steps = list(impute = list(method = "median")),
+                   task = "gaussian")
> fit$transform(x)
   a  b
1 -1 -1
2  1  0
3  0  1
> 
